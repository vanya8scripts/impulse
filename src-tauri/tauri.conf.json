{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Импульс",
  "version": "1.0.0",
  "identifier": "ru.impulse.desktop",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "bun install && bun run dev",
    "beforeBuildCommand": "bun install && bun run build:pages"
  },
  "app": {
    "windows": [
      {
        "title": "Импульс",
        "width": 1200,
        "height": 800,
        "minWidth": 360,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "SocialNetworking",
    "shortDescription": "Импульс — мессенджер",
    "longDescription": "Импульс — быстрый и безопасный мессенджер с шифрованием, звонками, файлами и играми."
  }
}
